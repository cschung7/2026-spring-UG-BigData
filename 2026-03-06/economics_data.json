    "inflation_calculation": {
      "example_1": {
        "title": "2022년 한국 인플레이션율",
        "current_price_index": 105.1,
        "previous_price_index": 100.0,
        "result": 5.1,
        "formula": "인플레이션율 = ((P1 - P0) / P0) × 100",
        "calculation": "((105.1 - 100.0) / 100.0) × 100 = 5.1%"
      }
    },
    
    "unemployment_calculation": {
      "example_1": {
        "title": "2023년 한국 실업률",
        "unemployed": 858000,
        "labor_force": 27662000,
        "result": 3.1,
        "formula": "실업률 = (실업자 수 / 경제활동인구) × 100",
        "calculation": "(858000 / 27662000) × 100 = 3.1%"
      }
    },
    
    "multiplier_effect": {
      "example_1": {
        "title": "한국의 정부지출승수 (MPC = 0.75)",
        "marginal_propensity_to_consume": 0.75,
        "result": 4.0,
        "formula": "승수 = 1 / (1 - MPC)",
        "calculation": "1 / (1 - 0.75) = 1 / 0.25 = 4.0",
        "interpretation": "정부지출 1조원 증가 시 국민소득 4조원 증가"
      },
      "example_2": {
        "title": "조세승수 계산 (MPC = 0.8)", 
        "marginal_propensity_to_consume": 0.8,
        "result": -4.0,
        "formula": "조세승수 = -MPC / (1 - MPC)",
        "calculation": "-0.8 / (1 - 0.8) = -0.8 / 0.2 = -4.0",
        "interpretation": "세금 1조원 증가 시 국민소득 4조원 감소"
      }
    },
    
