  "study_problems": {
    "basic_calculations": [
      {
        "id": 1,
        "type": "GDP계산",
        "question": "한 국가의 2024년 경제지표가 다음과 같다. 민간소비: 800조원, 민간투자: 200조원, 정부지출: 180조원, 수출: 300조원, 수입: 250조원. GDP는?",
        "given_data": {
          "consumption": 800,
          "investment": 200, 
          "government": 180,
          "exports": 300,
          "imports": 250
        },
        "answer": 1230,
        "solution": "GDP = C + I + G + (X - M) = 800 + 200 + 180 + (300 - 250) = 1230조원"
      },
      {
        "id": 2,
        "type": "인플레이션율",
        "question": "2023년 소비자물가지수가 108.5, 2024년이 112.3이라면 2024년 인플레이션율은?",
        "given_data": {
          "cpi_2023": 108.5,
          "cpi_2024": 112.3
        },
        "answer": 3.5,
        "solution": "인플레이션율 = ((112.3 - 108.5) / 108.5) × 100 = 3.5%"
      },
      {
        "id": 3,
        "type": "실업률",
        "question": "경제활동인구가 2,800만명이고 실업자가 98만명일 때 실업률은?",
        "given_data": {
          "labor_force": 28000000,
          "unemployed": 980000
        },
        "answer": 3.5,
        "solution": "실업률 = (980,000 / 28,000,000) × 100 = 3.5%"
      },
      {
        "id": 4,
        "type": "승수효과",
        "question": "한계소비성향이 0.75일 때 정부가 20조원을 추가 지출하면 국민소득 증가는?",
        "given_data": {
          "mpc": 0.75,
          "government_spending_increase": 20
        },
        "answer": 80,
        "solution": "승수 = 1/(1-0.75) = 4, 국민소득 증가 = 20 × 4 = 80조원"
      }
    ],
    
    "advanced_problems": [
      {
        "id": 1,
        "type": "IS-LM분석",
        "question": "확장적 재정정책과 긴축적 통화정책을 동시에 실시할 때의 효과를 분석하시오.",
        "concepts": ["IS곡선 이동", "LM곡선 이동", "균형점 변화"],
        "answer": "GDP는 불확실, 이자율은 상승"
      },
      {
        "id": 2, 
        "type": "개방경제",
        "question": "환율절하가 경제에 미치는 영향을 단기와 장기로 나누어 설명하시오.",
        "concepts": ["J-curve 효과", "마셜-러너 조건", "물가효과"],
        "answer": "단기: 무역수지 악화 가능, 장기: 무역수지 개선"
      }
    ]
  },

